rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin(seasonId) {
      return signedIn()
        && exists(/databases/$(database)/documents/quinielas/$(seasonId)/admins/$(request.auth.uid));
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function verifiedEmail() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function matchDoc(seasonId, matchId) {
      return /databases/$(database)/documents/quinielas/$(seasonId)/matches/$(matchId);
    }

    function beforeKickoff(seasonId, matchId) {
      return exists(matchDoc(seasonId, matchId))
        && get(matchDoc(seasonId, matchId)).data.kickoffAt is timestamp
        && request.time < get(matchDoc(seasonId, matchId)).data.kickoffAt;
    }

    function validScoreValue(value) {
      return value == '' || (value is int && value >= 0 && value <= 99);
    }

    function validAdvancePick(value) {
      return value == '' || value == 'home' || value == 'away';
    }

    function validPredictionDoc(seasonId, uid, matchId) {
      return request.resource.data.keys().hasOnly([
          'seasonId',
          'uid',
          'matchId',
          'home',
          'away',
          'advances',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'seasonId',
          'uid',
          'matchId',
          'home',
          'away',
          'advances'
        ])
        && request.resource.data.seasonId == seasonId
        && request.resource.data.uid == uid
        && request.resource.data.matchId == matchId
        && validScoreValue(request.resource.data.home)
        && validScoreValue(request.resource.data.away)
        && validAdvancePick(request.resource.data.advances);
    }

    match /quinielas/{seasonId} {
      allow read: if true;
      allow write: if false;

      match /matches/{matchId} {
        allow read: if true;
        allow write: if isAdmin(seasonId);
      }

      match /participants/{uid} {
        allow read: if true;
        allow create, update: if owns(uid)
          && request.resource.data.uid == uid
          && request.resource.data.seasonId == seasonId;
        allow delete: if false;
      }

      match /predictions/{uid} {
        allow read: if owns(uid) || isAdmin(seasonId);
        allow create, update, delete: if false;

        match /matches/{matchId} {
          allow read: if owns(uid) || isAdmin(seasonId);
          allow create, update: if owns(uid)
            && verifiedEmail()
            && beforeKickoff(seasonId, matchId)
            && validPredictionDoc(seasonId, uid, matchId);
          allow delete: if owns(uid)
            && verifiedEmail()
            && beforeKickoff(seasonId, matchId);
        }
      }

      match /admin/{docId} {
        allow read: if docId == 'results';
        allow write: if isAdmin(seasonId);
      }

      match /public/{docId} {
        allow read: if true;
        allow write: if isAdmin(seasonId);
      }

      match /admins/{uid} {
        allow read: if owns(uid) || isAdmin(seasonId);
        allow write: if false;
      }
    }
  }
}
